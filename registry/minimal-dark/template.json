{
  "id": "minimal-dark",
  "name": "Minimal Dark",
  "version": "0.1.0",
  "domain": "presentation",
  "spec": "deck-contract/1",
  "blocks": {
    "stat-callout": {
      "id": "block_stat",
      "type": "stat-callout",
      "role": "key-metric",
      "content": { "value": "0x", "label": "metric", "delta": "" },
      "style": { "valueColor": "token://color/accent", "valueFont": "token://font/heading", "valueSize": "token://type/h1", "labelColor": "token://color/muted", "labelSize": "token://type/caption" }
    },
    "bullet-list": {
      "id": "block_bullets",
      "type": "bullet-list",
      "role": "supporting-points",
      "content": { "items": ["First point", "Second point", "Third point"] },
      "style": { "color": "token://color/text", "marker": "token://color/accent", "size": "token://type/body" }
    },
    "quote": {
      "id": "block_quote",
      "type": "heading",
      "role": "quote",
      "content": { "text": "A short, memorable quote." },
      "style": { "color": "token://color/text", "font": "token://font/heading", "size": "token://type/h2" }
    },
    "image-caption": {
      "id": "block_image",
      "type": "image-caption",
      "role": "visual",
      "content": { "src": "asset://images/placeholder.png", "alt": "image", "caption": "Caption" },
      "style": { "radius": "token://radius/md", "captionColor": "token://color/muted", "captionSize": "token://type/caption" }
    },
    "heading": {
      "id": "block_heading",
      "type": "heading",
      "role": "heading",
      "content": { "text": "New heading" },
      "style": { "color": "token://color/text", "font": "token://font/heading", "size": "token://type/h1" }
    },
    "subtitle": {
      "id": "block_subtitle",
      "type": "heading",
      "role": "subtitle",
      "content": { "text": "New subtitle" },
      "style": { "color": "token://color/muted", "font": "token://font/body", "size": "token://type/h2" }
    },
    "bar-chart": {
      "id": "block_barchart",
      "type": "bar-chart",
      "role": "chart",
      "content": { "data": [
        { "label": "Q1", "value": 12 },
        { "label": "Q2", "value": 19 },
        { "label": "Q3", "value": 27 },
        { "label": "Q4", "value": 38 }
      ] },
      "style": { "bar": "token://color/accent", "labelColor": "token://color/muted", "color": "token://color/text" }
    },
    "table": {
      "id": "block_table",
      "type": "table",
      "role": "table",
      "content": {
        "columns": ["Plan", "Price", "Seats"],
        "rows": [
          ["Starter", "$0", "1"],
          ["Team", "$29", "10"],
          ["Scale", "$99", "50"]
        ]
      },
      "style": { "color": "token://color/text", "headColor": "token://color/accent", "lineColor": "token://color/surface" }
    },
    "two-column": {
      "id": "block_twocol",
      "type": "two-column",
      "role": "layout",
      "layout": { "direction": "row", "gap": "token://space/xl" },
      "children": [
        {
          "id": "block_twocol_l",
          "type": "container",
          "layout": { "direction": "column", "gap": "token://space/md", "sizing": { "width": "fill" } },
          "children": [
            { "id": "block_twocol_l_h", "type": "heading", "content": { "text": "Left heading" }, "style": { "color": "token://color/text", "font": "token://font/heading", "size": "token://type/h2" } },
            { "id": "block_twocol_l_b", "type": "bullet-list", "content": { "items": ["First point", "Second point"] }, "style": { "color": "token://color/text", "marker": "token://color/accent", "size": "token://type/body" } }
          ]
        },
        {
          "id": "block_twocol_r",
          "type": "container",
          "layout": { "direction": "column", "gap": "token://space/md", "sizing": { "width": "fill" } },
          "children": [
            { "id": "block_twocol_r_h", "type": "heading", "content": { "text": "Right heading" }, "style": { "color": "token://color/text", "font": "token://font/heading", "size": "token://type/h2" } },
            { "id": "block_twocol_r_b", "type": "body", "content": { "text": "Supporting text on the right side of the slide." }, "style": { "color": "token://color/muted", "size": "token://type/body" } }
          ]
        }
      ]
    }
  }
}
